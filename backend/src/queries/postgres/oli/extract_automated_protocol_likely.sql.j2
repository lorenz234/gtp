{#
    Get automated labeler attestations where owner_project = 'protocol-contract-likely'.

    These are contracts that the automated labeler classified with strong protocol signals
    (verified source, governance/staking/bridge events, GitHub presence, or high-confidence
    non-trading category) but where no owner_project is known.

    The sentinel value 'protocol-contract-likely' is written by the automated labeler so that
    these contracts surface in 'Label Pool Reattest' for a human reviewer to assign a real
    owner_project slug. The automated labeler attester (0xaDbf...) is excluded from the
    standard extract_labels_for_review.sql.j2 query, so this separate query is needed.

    Parameters:
    - date: Only get attestations after this date (default: '2020-01-01')
#}

{% set date = date | default('2020-01-01') %}

WITH filtered_labels AS (
  SELECT
    uid, chain_id, address, tag_id, tag_value, attester, "time"
  FROM
    public.labels
  WHERE
    attester = decode('aDbf2b56995b57525Aa9a45df19091a2C5a2A970', 'hex')
    AND chain_id IN (SELECT caip2 FROM sys_main_conf)
    AND tag_id IN ('contract_name', 'owner_project', 'usage_category')
    AND "time" > '{{ date }}'::timestamp
),

pivoted_data AS (
  SELECT
    (array_agg(address))[1] AS address,
    (array_agg(attester))[1] AS attester,
    MAX(chain_id) AS chain_id,
    MAX(CASE WHEN tag_id = 'contract_name' THEN tag_value END) AS contract_name,
    MAX(CASE WHEN tag_id = 'owner_project' THEN tag_value END) AS owner_project,
    MAX(CASE WHEN tag_id = 'usage_category' THEN tag_value END) AS usage_category
  FROM
    filtered_labels
  GROUP BY
    uid
)

SELECT * FROM pivoted_data
WHERE owner_project = 'protocol-contract-likely';
